{
    "env": {
        "HTTP_PROXY": "http://user:pass@host:port",
        "HTTPS_PROXY": "http://user:pass@host:port",
        "HF_HUB_OFFLINE": "0",
        "GEMINI_API_KEY": "YOUR_API_KEY"
    },
    "telegram_transport": {
        "bot_token": "YOUR_BOT_TOKEN",
        "allowed_user_ids": [123456789]
    },
    "agent": {
        "model_name": "gemini-3-flash-preview",
        "transcription_model_name": "gemini-3-flash-preview",
        "api_key": "$GEMINI_API_KEY",
        "include_thoughts": true,
        "memory_compressor": {
            "__class__": "src.memory.compressors.smart.SmartCompressor",
            "api_key": "$GEMINI_API_KEY",
            "model_name": "gemini-3-flash-preview"
        },
        "memory_providers": [
            {
                "__class__": "src.memory.providers.fact.FactProvider",
                "model_name": "gemini-2.5-flash",
                "api_key": "$GEMINI_API_KEY",
                "auto_recall": false,
                "auto_consolidate": true,
                "retain_mission": "Focus on facts about the user's life, work, relationships, and goals. Prioritize personal details over generic information.",
                "custom_instructions": "",
                "embedding_model": {
                    "provider": "google",
                    "model": "models/gemini-embedding-001",
                    "api_key": "$GEMINI_API_KEY"
                }
            },
            {
                "__class__": "src.memory.providers.hindsight.HindsightProvider",
                "bank_id": "slonagent",
                "llm_provider": "gemini",
                "llm_api_key": "$GEMINI_API_KEY",
                "llm_model": "gemini-2.5-flash"
            },
            {
                "__class__": "src.memory.providers.personality.PersonalityProvider"
            },
            {
                "__class__": "src.memory.providers.summary.SummaryProvider",
                "model_name": "gemini-3-flash-preview",
                "api_key": "$GEMINI_API_KEY"
            },
            {
                "__class__": "src.memory.providers.simplemem.SimpleMemProvider",
                "model_name": "gemini-3-flash-preview",
                "api_key": "$GEMINI_API_KEY"
            },
            {
                "__class__": "src.memory.providers.semantic.SemanticProvider",
                "model_name": "gemini-3-flash-preview",
                "api_key": "$GEMINI_API_KEY"
            },
            {
                "__class__": "src.memory.providers.tool.ToolProvider",
                "model_name": "gemini-3-flash-preview",
                "api_key": "$GEMINI_API_KEY"
            }
        ],
        "skills": [
            {"__class__": "src.skills.config.ConfigSkill"},
            {"__class__": "src.skills.sandbox.SandboxSkill"},
            {"__class__": "src.skills.skill_writer.SkillWriterSkill"},
            {"__class__": "src.skills.nano_banana.NanoBananaSkill", "api_key": "$GEMINI_API_KEY"}
        ]
    }
}
