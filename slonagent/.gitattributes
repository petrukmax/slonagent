# Normalize line endings to LF in the repository
* text=auto eol=lf

# Python source files — always LF
*.py text eol=lf

# JSON/YAML configs — always LF
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf

# Batch scripts — keep CRLF on Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.ico binary
